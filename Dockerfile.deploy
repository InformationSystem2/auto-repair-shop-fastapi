FROM python:3.10-slim

ENV PYTHONDONTWRITEBYTECODE 1
ENV PYTHONUNBUFFERED 1

WORKDIR /app

# Mantenemos las dependencias del sistema (quitamos ffmpeg si no lo necesitas para procesar video/audio)
RUN apt-get update && apt-get install -y \
    libpq-dev \
    gcc \ 
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Comando de inicio limpio y rápido. Sin migraciones.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080", "--proxy-headers", "--forwarded-allow-ips='*'", "--timeout-keep-alive", "5"]
